# MISSION-CONTROL backend environment (host device only). Copy to .env.
# Matches docker-compose.yml defaults.
DATABASE_URL=postgres://mission:mission@localhost:5432/mission_control

# Password required to view the dashboard (any device on the LAN).
DASHBOARD_PASSWORD=change-me

# Optional: explicit secret for signing login cookies. If unset, it is derived
# from DASHBOARD_PASSWORD (so changing the password logs everyone out).
# SESSION_SECRET=
